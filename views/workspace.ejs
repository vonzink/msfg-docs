<div class="workspace">

  <!-- MISMO Import (auto-populate documents) -->
  <div class="mismo-drop" id="mismoDrop">
    <input type="file" id="mismoFile" accept=".xml,text/xml,application/xml" class="u-sr-only">
    <div class="mismo-drop__inner">
      <div class="mismo-drop__icon" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
          <polyline points="14 2 14 8 20 8"></polyline>
          <line x1="12" y1="18" x2="12" y2="12"></line>
          <line x1="9" y1="15" x2="15" y2="15"></line>
        </svg>
      </div>
      <div class="mismo-drop__text">
        <strong>Import MISMO XML</strong>
        <span>Drag & drop a MISMO file here to auto-populate documents</span>
      </div>
      <label class="btn btn-sm btn-ghost mismo-drop__browse" id="mismoBrowse" for="mismoFile">Browse</label>
    </div>
    <div class="mismo-drop__active u-hidden" id="mismoActive">
      <div class="mismo-drop__badge">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
        MISMO loaded
      </div>
      <div class="mismo-drop__meta" id="mismoMeta">—</div>
      <button class="btn btn-sm btn-link mismo-drop__clear" id="mismoClear" type="button">Clear</button>
    </div>
  </div>

  <!-- Toolbar -->
  <div class="workspace__toolbar">
    <div class="workspace__toolbar-left">
      <h1 class="workspace__title">Document Workspace</h1>
      <span class="workspace__count" id="wsCount">0 active</span>
    </div>
    <div class="workspace__toolbar-right">
      <button class="btn btn-sm btn-ghost" id="wsCollapseAll" title="Collapse all">Collapse All</button>
      <button class="btn btn-sm btn-ghost" id="wsClearAll" title="Remove all">Clear All</button>
      <button class="btn btn-sm btn-primary" id="wsToggleSelector">Add Document</button>
    </div>
  </div>

  <!-- Document Selector Drawer -->
  <div class="workspace__selector u-hidden" id="wsSelector">
    <div class="workspace__selector-inner">
      <input type="text" class="workspace__search" id="wsSelectorSearch" placeholder="Search documents..." autocomplete="off">
      <div class="workspace__selector-grid" id="wsSelectorGrid">
        <% categories.forEach(cat => { %>
          <div class="workspace__selector-group" data-cat="<%= cat.id %>">
            <div class="workspace__selector-label" data-border-color="<%= cat.color %>">
              <%= cat.label %>
            </div>
            <% documents.filter(d => d.category === cat.id).forEach(doc => { %>
              <button class="workspace__selector-btn" data-type="document" data-slug="<%= doc.slug %>" data-name="<%= doc.name.toLowerCase() %>">
                <span class="workspace__selector-icon"><%= doc.icon %></span>
                <span class="workspace__selector-name"><%= doc.name %></span>
              </button>
            <% }) %>
          </div>
        <% }) %>
        <% if (templates && templates.length) { %>
          <%
            // Bucket templates by investorName. Templates without one fall
            // into "Generic Templates"; per-investor groups render first
            // (alphabetical) so the loan officer can scan to their bank.
            const _byInvestor = {};
            templates.forEach(t => {
              const key = (t.investorName || '').trim();
              const bucket = key || '__generic__';
              if (!_byInvestor[bucket]) _byInvestor[bucket] = [];
              _byInvestor[bucket].push(t);
            });
            const _investorNames = Object.keys(_byInvestor)
              .filter(k => k !== '__generic__')
              .sort((a, b) => a.localeCompare(b));
          %>
          <% _investorNames.forEach(name => { %>
            <div class="workspace__selector-group" data-cat="templates">
              <div class="workspace__selector-label" data-border-color="#6b7280">
                <%= name %>
              </div>
              <% _byInvestor[name].forEach(tpl => { %>
                <button class="workspace__selector-btn" data-type="template" data-slug="<%= tpl.slug %>" data-name="<%= (tpl.name || '').toLowerCase() + ' ' + name.toLowerCase() %>">
                  <span class="workspace__selector-icon"><%= tpl.icon || '📄' %></span>
                  <span class="workspace__selector-name"><%= tpl.name %></span>
                </button>
              <% }) %>
            </div>
          <% }) %>
          <% if (_byInvestor['__generic__']) { %>
            <div class="workspace__selector-group" data-cat="templates">
              <div class="workspace__selector-label" data-border-color="#9ca3af">
                Generic Templates
              </div>
              <% _byInvestor['__generic__'].forEach(tpl => { %>
                <button class="workspace__selector-btn" data-type="template" data-slug="<%= tpl.slug %>" data-name="<%= (tpl.name || '').toLowerCase() %>">
                  <span class="workspace__selector-icon"><%= tpl.icon || '📄' %></span>
                  <span class="workspace__selector-name"><%= tpl.name %></span>
                </button>
              <% }) %>
            </div>
          <% } %>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Active Document Panels -->
  <div class="workspace__panels" id="wsPanels">
    <div class="workspace__empty" id="wsEmpty">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="8" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="12" y2="14"/></svg>
      <h3>No documents selected</h3>
      <p>Click "Add Document" above to start building your workspace.</p>
    </div>
  </div>
</div>
