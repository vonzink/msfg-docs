<div class="doc-page">
  <div class="doc-page__header">
    <h1><%= templateConfig.icon || '📄' %> <%= templateConfig.name %></h1>
    <% if (templateConfig.description) { %><p><%= templateConfig.description %></p><% } %>
  </div>

  <div class="doc-page__body">

    <!-- Investor picker — shown only when at least one field is mapped to an investor source -->
    <div class="calc-section" id="tplInvestorSection" hidden>
      <h2><span class="section-number">★</span> Investor record</h2>
      <p class="text-muted" style="margin-top:0;">
        Pick an investor to fill mapped fields automatically. Auto-matched on MISMO import when a loan number matches.
      </p>
      <div class="form-grid">
        <div class="form-group form-group--full">
          <label for="tplInvestorSelect">Investor</label>
          <select id="tplInvestorSelect">
            <option value="">Select investor…</option>
          </select>
          <p class="text-muted" id="tplInvestorHint" hidden></p>
        </div>
      </div>
    </div>

    <!-- Dynamic form sections rendered by JS from field config -->
    <div id="tplFillSections">
      <!-- JS renders grouped fields here -->
    </div>

    <!-- Action bar -->
    <div class="action-bar doc-actions">
      <button type="button" class="btn btn-primary icon-inline" id="tplDownloadBtn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Download filled PDF
      </button>
      <button type="button" class="btn btn-secondary icon-inline" id="tplViewBtn" title="Open the filled PDF in a new tab (use browser's Save As / Print)">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
        View filled PDF
      </button>
      <button type="button" class="btn btn-secondary icon-inline" id="tplSaveDraftBtn" title="Save current values to resume later on this device / account">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
        Save draft
      </button>
      <a class="btn btn-secondary icon-inline" href="<%= basePath %><%= templateConfig.apiBase || ('/templates/api/' + templateConfig.id) %>/download" target="_blank" rel="noopener noreferrer">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        Blank PDF
      </a>
      <button type="button" class="btn btn-secondary icon-inline" data-action="doc-print">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
        Print
      </button>
      <button type="button" class="btn btn-secondary icon-inline" data-action="doc-email">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        Email
      </button>
      <span class="text-muted" id="tplDraftStatus" style="align-self:center;margin-left:var(--space-sm,12px);font-size:0.85rem;"></span>
    </div>

  </div>
</div>

<script type="application/json" id="tplConfig"><%- JSON.stringify(templateConfig) %></script>
