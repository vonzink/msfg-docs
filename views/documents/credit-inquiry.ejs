<div class="doc-page">
  <div class="doc-page__header">
    <h1><%= doc.icon %> <%= doc.name %></h1>
    <p><%= doc.description %></p>
  </div>

  <div class="doc-page__body">

    <!-- Section 1: Sender Information (from MISMO) -->
    <div class="calc-section">
      <h2><span class="section-number">1</span> Sender Information</h2>
      <div class="form-grid">
        <div class="form-group">
          <label for="senderName">Borrower Full Name</label>
          <input type="text" id="senderName" placeholder="Borrower name">
        </div>
        <div class="form-group">
          <label for="coBorrowerName">Co-Borrower (if applicable)</label>
          <input type="text" id="coBorrowerName" placeholder="Co-borrower name">
        </div>
        <div class="form-group">
          <label for="subjectPropertyAddress">Subject Property Address</label>
          <input type="text" id="subjectPropertyAddress" placeholder="Subject property address">
        </div>
        <div class="form-group">
          <label for="loanNumber">Loan Number</label>
          <input type="text" id="loanNumber" placeholder="Loan number">
        </div>
        <div class="form-group">
          <label for="letterDate">Today's Date</label>
          <input type="text" id="letterDate" readonly>
        </div>
      </div>
    </div>

    <!-- Section 2: Inquiries -->
    <div class="calc-section">
      <h2><span class="section-number">2</span> Inquiries</h2>
      <div class="credit-inquiry__rows">
        <div class="credit-inquiry__rows-actions">
          <button type="button" class="btn btn-sm btn-ghost" id="addInquiryRow">Add Inquiry</button>
        </div>
        <div class="credit-inquiry__table-wrap">
          <table class="credit-inquiry__table" id="inquiryTable">
            <thead>
              <tr>
                <th style="width:60px;">No.</th>
                <th style="width:170px;">Inquiry Date</th>
                <th style="width:240px;">Creditor</th>
                <th>Explanation</th>
                <th style="width:60px;"></th>
              </tr>
            </thead>
            <tbody id="inquiryTbody"></tbody>
          </table>
        </div>
      </div>
    </div>

    <%- include('../partials/letter-settings-panel') %>

    <!-- Section 3: Letter Preview — editable. Click anywhere in the
         rendered letter to type. Manual edits stick until "Reset
         preview" is pressed. Same UX as the Address LOX and
         Pre-Approval previews. -->
    <div class="calc-section">
      <h2>
        <span class="section-number">3</span> Letter Preview
        <button type="button" class="btn btn-link btn-sm" id="ciResetPreview" title="Discard manual edits and rebuild from the fields above">Reset preview</button>
      </h2>
      <div id="letterPreview" class="letter-preview" contenteditable="true" spellcheck="true">
        <p class="text-muted text-center">Fill in the fields above to generate your letter.</p>
      </div>
      <p class="text-muted" style="margin:var(--space-xs) 0 0;font-size:0.82rem;">
        Click anywhere in the preview to edit. Manual edits stick until you press <strong>Reset preview</strong>.
      </p>
    </div>

    <%- include('../partials/doc-actions-credit-inquiry') %>
  </div>
</div>
