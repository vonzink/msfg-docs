<div class="doc-page">
  <div class="doc-page__header">
    <h1><%= doc.icon %> <%= doc.name %></h1>
    <p><%= doc.description %></p>
  </div>

  <div class="doc-page__body">

    <!-- Section 1: Borrower Information -->
    <div class="calc-section">
      <h2><span class="section-number">1</span> Borrower Information</h2>
      <div class="form-grid u-grid-2col">
        <div class="form-group">
          <label for="borrowerName">Borrower Name</label>
          <input type="text" id="borrowerName" placeholder="John Doe">
        </div>
        <div class="form-group">
          <label for="loanNumber">Loan Number</label>
          <input type="text" id="loanNumber" placeholder="LN-2026-001234">
        </div>
        <div class="form-group">
          <label for="currentAddress">Current Address</label>
          <input type="text" id="currentAddress" placeholder="456 Oak Ave, City, ST 12345">
        </div>
        <div class="form-group">
          <label for="letterDate">Letter Date</label>
          <input type="text" id="letterDate" placeholder="MM/DD/YYYY" inputmode="numeric">
        </div>
      </div>
    </div>

    <!-- Section 2: Address history rows — repeating UX. Add a row per
         past/alternate address with date range + explanation. -->
    <div class="calc-section">
      <h2><span class="section-number">2</span> Past / alternate addresses</h2>
      <p class="text-muted" style="margin-top:0;">
        Add one row per address that needs explaining. Use the date range to anchor each move; the
        explanation prints under the address in the letter.
      </p>
      <div id="addressRows"></div>
      <div class="lox-row-actions">
        <button type="button" class="btn btn-secondary btn-sm" id="addAddressRow">+ Add address</button>
      </div>
    </div>

    <%- include('../partials/letter-settings-panel') %>

    <!-- Section 3: Letter Preview — editable. Auto-fills from the
         fields above, but you can also click into the preview and
         tweak the wording directly. Use "Reset preview" to throw
         away your edits and re-render from the form. -->
    <div class="calc-section">
      <h2>
        <span class="section-number">3</span> Letter Preview
        <button type="button" class="btn btn-link btn-sm lox-reset-preview" id="loxResetPreview" title="Discard manual edits and rebuild from the fields above">Reset preview</button>
      </h2>
      <div id="letterPreview" class="letter-preview" contenteditable="true" spellcheck="true">
        <p class="text-muted text-center">Fill in the fields above to generate your letter of explanation.</p>
      </div>
      <p class="text-muted" style="margin:var(--space-xs) 0 0;font-size:0.82rem;">
        Click anywhere in the preview to edit the wording directly. Manual edits stick until you press <strong>Reset preview</strong> or change a field above.
      </p>
    </div>

    <!-- Action bar — Download + Print + Email. The 4-style picker
         above controls both the in-page preview AND the downloaded
         PDF (same theme for both). -->
    <div class="action-bar doc-actions">
      <button type="button" class="btn btn-primary icon-inline" id="btnAddressLoxDownloadPdf">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Download PDF
      </button>
      <button type="button" class="btn btn-secondary icon-inline" data-action="doc-print">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
        Print
      </button>
      <button type="button" class="btn btn-secondary icon-inline" data-action="doc-email">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        Email
      </button>
    </div>
  </div>
</div>
