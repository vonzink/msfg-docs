<div class="doc-page">
  <div class="doc-page__header">
    <h1><%= doc.icon %> <%= doc.name %></h1>
    <p><%= doc.description %></p>
  </div>

  <div class="doc-page__body">

    <!-- Section 1: Invoice Info -->
    <div class="calc-section">
      <h2><span class="section-number">1</span> Invoice Information</h2>
      <div class="form-grid">
        <div class="form-group">
          <label for="invoiceNumber">Invoice #</label>
          <input type="text" id="invoiceNumber" placeholder="INV-001">
        </div>
        <div class="form-group">
          <label for="invoiceDate">Invoice Date</label>
          <input type="date" id="invoiceDate">
        </div>
        <div class="form-group">
          <label for="dueDate">Due Date</label>
          <input type="date" id="dueDate">
        </div>
      </div>
    </div>

    <!-- Section 2: From / To -->
    <div class="calc-section">
      <h2><span class="section-number">2</span> Parties</h2>
      <div class="form-grid u-grid-2col">
        <div class="form-group">
          <label for="fromName">From (Business Name)</label>
          <input type="text" id="fromName" placeholder="Mountain State Financial Group">
        </div>
        <div class="form-group">
          <label for="toName">To (Client Name)</label>
          <input type="text" id="toName" placeholder="Client Name">
        </div>
        <div class="form-group">
          <label for="fromAddress">From Address</label>
          <input type="text" id="fromAddress" placeholder="123 Business St, City, ST 12345">
        </div>
        <div class="form-group">
          <label for="toAddress">To Address</label>
          <input type="text" id="toAddress" placeholder="456 Client Ave, City, ST 12345">
        </div>
      </div>
    </div>

    <!-- Section 3: Line Items -->
    <div class="calc-section">
      <h2><span class="section-number">3</span> Line Items</h2>
      <div class="u-overflow-x">
        <table class="data-table" id="lineItemsTable">
          <thead>
            <tr>
              <th style="width:40%">Description</th>
              <th style="width:15%">Qty</th>
              <th style="width:20%">Unit Price</th>
              <th style="width:20%">Amount</th>
              <th style="width:5%"></th>
            </tr>
          </thead>
          <tbody id="lineItems">
            <tr class="line-item">
              <td><input type="text" class="item-desc" placeholder="Service or product"></td>
              <td><input type="number" class="item-qty" value="1" min="0" step="1"></td>
              <td><input type="text" class="item-price" placeholder="$0.00"></td>
              <td class="item-amount">$0.00</td>
              <td><button type="button" class="btn btn-sm" data-action="remove-row" title="Remove">&times;</button></td>
            </tr>
          </tbody>
        </table>
      </div>
      <div class="btn-group u-mt-sm">
        <button type="button" class="btn btn-sm btn-ghost" id="addLineItem">+ Add Line Item</button>
      </div>
    </div>

    <!-- Section 4: Totals -->
    <div class="calc-section">
      <h2><span class="section-number">4</span> Totals</h2>
      <div class="form-grid u-grid-2col">
        <div class="form-group">
          <label for="taxRate">Tax Rate (%)</label>
          <input type="number" id="taxRate" value="0" min="0" step="0.01">
        </div>
        <div class="form-group">
          <label for="discount">Discount</label>
          <input type="text" id="discount" placeholder="$0.00">
        </div>
      </div>
      <div class="results-grid u-mt-md">
        <div class="result-card">
          <div class="result-card__label">Subtotal</div>
          <div class="result-card__value" id="resultSubtotal">$0.00</div>
        </div>
        <div class="result-card">
          <div class="result-card__label">Tax</div>
          <div class="result-card__value" id="resultTax">$0.00</div>
        </div>
        <div class="result-card">
          <div class="result-card__label">Total Due</div>
          <div class="result-card__value" id="resultTotal">$0.00</div>
        </div>
      </div>
    </div>

    <!-- Section 5: Payment Instructions -->
    <div class="calc-section">
      <h2><span class="section-number">5</span> Payment Instructions</h2>
      <div class="form-group form-group--full">
        <textarea id="paymentInstructions" rows="3" placeholder="Please make checks payable to... Wire transfer instructions..."></textarea>
      </div>
    </div>

    <%- include('../partials/doc-actions') %>
  </div>
</div>
