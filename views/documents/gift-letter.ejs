<div class="doc-page">
  <div class="doc-page__header">
    <h1><%= doc.icon %> <%= doc.name %></h1>
    <p><%= doc.description %></p>
  </div>

  <div class="doc-page__body">

    <!-- Section 1: Loan / borrower (auto-filled from MISMO when imported) -->
    <div class="calc-section">
      <h2><span class="section-number">1</span> Loan &amp; recipient</h2>
      <div class="form-grid u-grid-2col">
        <div class="form-group">
          <label for="giftLoanNumber">Loan number</label>
          <input type="text" id="giftLoanNumber" placeholder="From MISMO / LOS" autocomplete="off">
        </div>
        <div class="form-group">
          <label for="giftRecipientName">Recipient (borrower) name</label>
          <input type="text" id="giftRecipientName" placeholder="Borrower full name" autocomplete="name">
        </div>
        <div class="form-group form-group--full">
          <label for="giftPropertyAddress">Subject property address</label>
          <input type="text" id="giftPropertyAddress" placeholder="Street, City, ST ZIP" autocomplete="off">
        </div>
        <div class="form-group">
          <label for="giftLetterDate">Letter date</label>
          <input type="text" id="giftLetterDate" placeholder="MM/DD/YYYY" inputmode="numeric">
        </div>
      </div>
    </div>

    <!-- Section 2: Gift facts -->
    <div class="calc-section">
      <h2><span class="section-number">2</span> Gift</h2>
      <div class="form-grid u-grid-2col">
        <div class="form-group">
          <label for="giftAmount">Gift amount</label>
          <input type="text" id="giftAmount" placeholder="$5,000" inputmode="decimal">
        </div>
        <div class="form-group">
          <label for="giftFundTransferDate">Fund transfer date</label>
          <input type="text" id="giftFundTransferDate" placeholder="MM/DD/YYYY" inputmode="numeric">
        </div>
        <div class="form-group form-group--full">
          <label for="giftSourceOfGift">Source of gift funds</label>
          <input type="text" id="giftSourceOfGift" placeholder="e.g. Wells Fargo checking #...4321">
        </div>
      </div>
    </div>

    <!-- Section 3: Donor info -->
    <div class="calc-section">
      <h2><span class="section-number">3</span> Donor</h2>
      <div class="form-grid u-grid-2col">
        <div class="form-group">
          <label for="giftDonorName">Donor name</label>
          <input type="text" id="giftDonorName" placeholder="Full name" autocomplete="name">
        </div>
        <div class="form-group">
          <label for="giftRelationshipToDonor">Relationship to recipient</label>
          <input type="text" id="giftRelationshipToDonor" placeholder="e.g. Parent, Spouse, Sibling">
        </div>
        <div class="form-group">
          <label for="giftDonorPhone">Donor phone</label>
          <input type="text" id="giftDonorPhone" placeholder="(555) 555-1234" inputmode="tel" autocomplete="tel">
        </div>
        <div class="form-group">
          <label for="giftDonorEmail">Donor email</label>
          <input type="email" id="giftDonorEmail" placeholder="name@example.com" autocomplete="email">
        </div>
        <div class="form-group form-group--full">
          <label for="giftDonorAddress">Donor address</label>
          <input type="text" id="giftDonorAddress" placeholder="Street, City, ST ZIP" autocomplete="address-line1">
        </div>
      </div>
    </div>

    <%- include('../partials/letter-style-picker') %>

    <!-- Section 4: Letter Preview — editable. Click to type directly
         in the rendered letter. The Download button below always
         regenerates the PDF from the field values above (so manual
         edits in the preview stay browser-side; if you want them in
         the printed PDF, type them into the fields and click "Reset
         preview" to refresh). -->
    <div class="calc-section">
      <h2>
        <span class="section-number">4</span> Letter Preview
        <button type="button" class="btn btn-link btn-sm" id="giftResetPreview" title="Discard manual edits and rebuild from the fields above">Reset preview</button>
      </h2>
      <div id="letterPreview" class="letter-preview" contenteditable="true" spellcheck="true">
        <p class="text-muted text-center">Fill in the fields above to generate your gift letter.</p>
      </div>
      <p class="text-muted" style="margin:var(--space-xs) 0 0;font-size:0.82rem;">
        Click anywhere in the preview to edit. Note: <strong>Download</strong> rebuilds the PDF from the form fields, not from manual edits in this preview.
      </p>
    </div>

    <!-- Action bar -->
    <div class="action-bar doc-actions">
      <button type="button" class="btn btn-primary icon-inline" id="btnGiftDownloadPdf">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Download Gift Letter PDF
      </button>
      <button type="button" class="btn btn-secondary icon-inline" data-action="doc-print">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
        Print
      </button>
      <button type="button" class="btn btn-secondary icon-inline" data-action="doc-email">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        Email
      </button>
    </div>
  </div>
</div>
