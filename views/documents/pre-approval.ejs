<div class="doc-page">
  <div class="doc-page__header">
    <h1><%= doc.icon %> <%= doc.name %></h1>
    <p><%= doc.description %></p>
  </div>

  <div class="doc-page__body">

    <!-- Section 1: Borrower Information -->
    <div class="calc-section">
      <h2><span class="section-number">1</span> Borrower Information</h2>
      <div class="form-grid">
        <div class="form-group">
          <label for="borrowerName">Borrower Name</label>
          <input type="text" id="borrowerName" placeholder="John & Jane Doe">
        </div>
        <div class="form-group">
          <label for="borrowerAddress">Current Address</label>
          <input type="text" id="borrowerAddress" placeholder="123 Main St, City, ST 12345">
        </div>
      </div>
    </div>

    <!-- Section 2: Loan Details -->
    <div class="calc-section">
      <h2><span class="section-number">2</span> Loan Details</h2>
      <div class="form-grid">
        <div class="form-group">
          <label for="loanType">Loan Type</label>
          <select id="loanType">
            <option value="Conventional">Conventional</option>
            <option value="FHA">FHA</option>
            <option value="VA">VA</option>
            <option value="USDA">USDA</option>
            <option value="Jumbo">Jumbo</option>
          </select>
        </div>
        <div class="form-group">
          <label for="loanPurpose">Loan Purpose</label>
          <select id="loanPurpose">
            <option value="Purchase">Purchase</option>
            <option value="Refinance">Refinance</option>
          </select>
        </div>
        <div class="form-group">
          <label for="approvalAmount">Pre-Approved Amount</label>
          <input type="text" id="approvalAmount" placeholder="$350,000">
        </div>
        <div class="form-group">
          <label for="interestRate">
            Interest Rate
            <label class="pre-approval__rate-toggle" style="font-weight:normal;font-size:0.82rem;margin-left:var(--space-sm);">
              <input type="checkbox" id="includeInterestRate" checked>
              Include in letter
            </label>
          </label>
          <input type="text" id="interestRate" placeholder="6.500%">
        </div>
        <div class="form-group">
          <label for="loanTerm">Loan Term</label>
          <select id="loanTerm">
            <option value="30-Year Fixed">30-Year Fixed</option>
            <option value="15-Year Fixed">15-Year Fixed</option>
            <option value="20-Year Fixed">20-Year Fixed</option>
            <option value="7/1 ARM">7/1 ARM</option>
            <option value="5/1 ARM">5/1 ARM</option>
          </select>
        </div>
        <div class="form-group">
          <label for="downPayment">Down Payment</label>
          <input type="text" id="downPayment" placeholder="$70,000">
        </div>
        <div class="form-group">
          <label for="expirationDate">Expiration Date</label>
          <input type="date" id="expirationDate">
        </div>
      </div>
    </div>

    <!-- Section 3: Loan Officer -->
    <div class="calc-section">
      <h2><span class="section-number">3</span> Loan Officer</h2>
      <div class="form-grid">
        <div class="form-group">
          <label for="loName">Name</label>
          <input type="text" id="loName" placeholder="Loan Officer Name">
        </div>
        <div class="form-group">
          <label for="loNMLS">NMLS#</label>
          <input type="text" id="loNMLS" placeholder="123456">
        </div>
        <div class="form-group">
          <label for="loPhone">Phone</label>
          <input type="text" id="loPhone" placeholder="(555) 123-4567">
        </div>
        <div class="form-group">
          <label for="loEmail">Email</label>
          <input type="email" id="loEmail" placeholder="lo@msfg.com">
        </div>
      </div>
    </div>

    <!-- Section 4: Conditions -->
    <div class="calc-section">
      <h2><span class="section-number">4</span> Conditions</h2>
      <div class="form-group form-group--full">
        <textarea id="conditions" rows="4" placeholder="Subject to verification of income, assets, employment, credit, and property appraisal..."></textarea>
      </div>
    </div>

    <%- include('../partials/letter-style-picker') %>

    <!-- Section 5: Letter Preview — editable. Click to type directly
         in the rendered letter; manual edits stick until "Reset
         preview" is pressed. -->
    <div class="calc-section">
      <h2>
        <span class="section-number">5</span> Letter Preview
        <button type="button" class="btn btn-link btn-sm" id="paResetPreview" title="Discard manual edits and rebuild from the fields above">Reset preview</button>
      </h2>
      <div id="letterPreview" class="letter-preview" contenteditable="true" spellcheck="true">
        <p class="text-muted text-center">Fill in the fields above to generate your pre-approval letter.</p>
      </div>
      <p class="text-muted" style="margin:var(--space-xs) 0 0;font-size:0.82rem;">
        Click anywhere in the preview to edit. Manual edits stick until you press <strong>Reset preview</strong>.
      </p>
    </div>

    <!-- Action bar — Download + Print + Email. The 4-style picker
         above controls both the in-page preview AND the downloaded
         PDF. -->
    <div class="action-bar doc-actions">
      <button type="button" class="btn btn-primary icon-inline" id="btnPreApprovalDownloadPdf">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Download PDF
      </button>
      <button type="button" class="btn btn-secondary icon-inline" data-action="doc-print">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
        Print
      </button>
      <button type="button" class="btn btn-secondary icon-inline" data-action="doc-email">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        Email
      </button>
    </div>
  </div>
</div>
