<!-- Letter appearance settings — per-user customizer that replaces the
     4-template picker. Controls persist to localStorage (shared across
     all borrower-letter docs) and apply live to the .letter-preview
     below AND to the exported PDF (each borrower doc sends the full
     settings object in its Download payload; lib/pdf/letterPdf.js
     honors it). Gear icon mirrors the msfg-calc settings affordance. -->
<div class="letter-settings" data-doc-slug="<%= (typeof doc !== 'undefined' && doc) ? doc.slug : '' %>">
  <div class="letter-settings__toolbar">
    <button type="button" class="letter-settings__gear" id="letterSettingsToggle" aria-expanded="false" aria-controls="letterSettingsPanel" title="Letter appearance settings">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="3"/>
        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
      </svg>
      <span>Letter appearance</span>
    </button>
    <button type="button" class="letter-settings__reset" id="letterSettingsReset" title="Reset all settings to defaults">Reset to defaults</button>
  </div>

  <div class="letter-settings__panel" id="letterSettingsPanel" hidden>
    <!-- Quick presets — apply a whole settings combo at once. -->
    <div class="letter-settings__row letter-settings__presets">
      <label class="letter-settings__label">Presets</label>
      <div class="letter-settings__preset-chips">
        <button type="button" class="letter-settings__preset" data-preset="classic">Classic</button>
        <button type="button" class="letter-settings__preset" data-preset="modern">Modern</button>
        <button type="button" class="letter-settings__preset" data-preset="branded">Branded</button>
        <button type="button" class="letter-settings__preset" data-preset="compact">Compact</button>
      </div>
    </div>

    <div class="letter-settings__grid">
      <div class="letter-settings__field">
        <label for="lsFontFamily">Font</label>
        <select id="lsFontFamily" data-setting="fontFamily">
          <option value="times">Serif — Times</option>
          <option value="helvetica">Sans-serif — Helvetica</option>
        </select>
      </div>
      <div class="letter-settings__field">
        <label for="lsFontSize">Font size</label>
        <select id="lsFontSize" data-setting="fontSize">
          <option value="9">9 pt — tight</option>
          <option value="10">10 pt</option>
          <option value="11">11 pt — default</option>
          <option value="12">12 pt</option>
          <option value="13">13 pt — large</option>
        </select>
      </div>
      <div class="letter-settings__field">
        <label for="lsAccentText">Accent color</label>
        <div class="letter-settings__color">
          <input type="color" id="lsAccent" data-setting="accent">
          <input type="text" id="lsAccentText" data-setting="accent" maxlength="7" placeholder="#2d6a4f">
        </div>
      </div>
      <div class="letter-settings__field">
        <label for="lsTableStyle">Table style</label>
        <select id="lsTableStyle" data-setting="tableStyle">
          <option value="plain">Plain</option>
          <option value="dotted">Dotted underlines</option>
          <option value="striped">Striped rows</option>
          <option value="accentKey">Accent key column</option>
          <option value="thin">Thin rule rows</option>
        </select>
      </div>
      <div class="letter-settings__field">
        <label for="lsTitleAlign">Title alignment</label>
        <select id="lsTitleAlign" data-setting="titleAlign">
          <option value="left">Left</option>
          <option value="center">Center</option>
        </select>
      </div>
      <div class="letter-settings__field">
        <label for="lsMargin">Margins</label>
        <select id="lsMargin" data-setting="margin">
          <option value="narrow">Narrow</option>
          <option value="normal">Normal</option>
          <option value="wide">Wide</option>
        </select>
      </div>
    </div>

    <div class="letter-settings__toggles">
      <label class="letter-settings__toggle"><input type="checkbox" data-setting="headerBand"> Header band</label>
      <label class="letter-settings__toggle"><input type="checkbox" data-setting="footerBand"> Footer band</label>
      <label class="letter-settings__toggle"><input type="checkbox" data-setting="leftRail"> Left accent rail</label>
      <label class="letter-settings__toggle"><input type="checkbox" data-setting="justify"> Justify body text</label>
    </div>
  </div>
</div>
