# Server
PORT=3004
PUBLIC_BASE_URL=http://localhost:3004

# If the browser loads documents from a different origin than this Node app, set the site origin only (no trailing slash, no /api suffix).
# Leave unset when everything is same-origin (normal local and single-host deploys).
# PUBLIC_APP_ORIGIN=http://localhost:3004

# URL prefix when mounted behind a reverse proxy (e.g. dashboard.msfgco.com/docs).
# Leave unset for standalone local dev. Must start with '/' and have no trailing slash.
# BASE_PATH=/docs

# AWS Cognito (JWT auth on /api/*). Leave unset for dev mode — requests get a mock user and pass through.
# COGNITO_REGION=us-west-1
# COGNITO_USER_POOL_ID=
# COGNITO_CLIENT_ID=
# COGNITO_ISSUER=

# MySQL (Form 4506-C investor dropdown). RDS is usually reachable only from EC2/VPN — not from a random laptop IP.
# MYSQL_HOST=
# MYSQL_PORT=3306
# MYSQL_USER=
# MYSQL_PASSWORD=
# MYSQL_DATABASE=msfg_mortgage_db
# Optional: defaults to investors
# MYSQL_INVESTORS_TABLE=investors
# Optional: DB column on investors that stores the LOS loan number (exact match to MISMO loan)
# MYSQL_INVESTORS_LOAN_COLUMN=lender_loan_number
# Optional: override path to AcroForm IRS PDF template (default public/documents/irs-form-4506-c.pdf)
# FORM_4506C_PDF_PATH=
